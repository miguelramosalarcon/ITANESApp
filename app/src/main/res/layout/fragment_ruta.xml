<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Mapa OSMDroid ocupa toda la pantalla -->
    <org.osmdroid.views.MapView
        android:id="@+id/mapa"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clickable="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/card_info"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Card inferior con info del recorrido -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_info"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="16dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Nombre del recorrido -->
            <TextView
                android:id="@+id/tv_nombre_recorrido"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:textColor="@color/text_primary"
                android:textStyle="bold" />

            <!-- Distancia y duración -->
            <TextView
                android:id="@+id/tv_distancia"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="4dp" />

            <!-- Botón iniciar navegación -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_iniciar_ruta"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/ruta_iniciar"
                android:layout_marginTop="12dp"
                style="@style/ButtonStyle.Primary" />

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- ProgressBar mientras carga la ruta -->
    <ProgressBar
        android:id="@+id/progress_ruta"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:indeterminateTint="@color/green_primary"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="@id/mapa"
        app:layout_constraintBottom_toBottomOf="@id/mapa"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>