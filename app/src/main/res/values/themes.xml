<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!--
        Tema principal de ITANES — Material 3
        Hereda de Theme.Material3.Light.NoActionBar
        para tener control total del AppBar desde cada Fragment
    -->
    <style name="Theme.ITANESApp" parent="Theme.Material3.Light.NoActionBar">

        <!-- Colores principales Material 3 -->
        <item name="colorPrimary">@color/green_primary</item>
        <item name="colorPrimaryVariant">@color/green_medium</item>
        <item name="colorOnPrimary">@color/text_on_primary</item>

        <!-- Colores secundarios -->
        <item name="colorSecondary">@color/orange_primary</item>
        <item name="colorOnSecondary">@color/text_on_secondary</item>

        <!-- Fondo y superficie -->
        <item name="android:colorBackground">@color/background</item>
        <item name="colorSurface">@color/surface</item>

        <!-- Texto -->
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>

        <!-- Error -->
        <item name="colorError">@color/error</item>

        <!-- Tipografía global -->
        <item name="android:fontFamily">@font/open_sans</item>

        <!-- StatusBar del mismo color que el primary -->
        <item name="android:statusBarColor">@color/green_primary</item>

    </style>

    <!-- ============================================================ -->
    <!-- ESTILOS DE TEXTO                                             -->
    <!-- ============================================================ -->

    <!-- Título grande — pantallas principales -->
    <style name="TextStyle.Title" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="fontFamily">@font/montserrat_bold</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <!-- Subtítulo — nombres de lugares -->
    <style name="TextStyle.Subtitle" parent="TextAppearance.Material3.TitleMedium">
        <item name="fontFamily">@font/montserrat_semibold</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <!-- Cuerpo — descripciones -->
    <style name="TextStyle.Body" parent="TextAppearance.Material3.BodyMedium">
        <item name="fontFamily">@font/open_sans</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <!-- Label pequeño — duración, categoría -->
    <style name="TextStyle.Label" parent="TextAppearance.Material3.LabelMedium">
        <item name="fontFamily">@font/open_sans_semibold</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <!-- ============================================================ -->
    <!-- ESTILOS DE BOTONES                                           -->
    <!-- ============================================================ -->

    <!-- Botón principal — "Iniciar Recorrido", "Ver Ruta" -->
    <style name="ButtonStyle.Primary" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/green_primary</item>
        <item name="android:textColor">@color/text_on_primary</item>
        <item name="fontFamily">@font/open_sans_semibold</item>
        <item name="cornerRadius">12dp</item>
    </style>

    <!-- Botón secundario — "Compartir", "Anterior" -->
    <style name="ButtonStyle.Secondary" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/green_primary</item>
        <item name="android:textColor">@color/green_primary</item>
        <item name="fontFamily">@font/open_sans_semibold</item>
        <item name="cornerRadius">12dp</item>
    </style>

    <!-- ============================================================ -->
    <!-- ESTILO DE CARDS                                              -->
    <!-- ============================================================ -->

    <style name="CardStyle.Recorrido" parent="Widget.Material3.CardView.Elevated">
        <item name="cardElevation">4dp</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="android:layout_marginBottom">16dp</item>
    </style>

</resources>